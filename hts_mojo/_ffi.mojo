def bgzf_dopen(fd: c_int, mode: Optional[UnsafePointer[c_char, ImmutUntrackedOrigin]]) abi("C") -> Optional[UnsafePointer[BGZF, MutUntrackedOrigin]]:
    """
    Open an existing file descriptor for reading or writing.
    
    @param fd    file descriptor
