    var cigar_tab: Optional[UnsafePointer[int8_t, ImmutUntrackedOrigin]]
    var target_name: Optional[UnsafePointer[Optional[UnsafePointer[c_char, MutUntrackedOrigin]], MutUntrackedOrigin]]
    var text: Optional[UnsafePointer[c_char, MutUntrackedOrigin]]
    var sdict: Optional[MutOpaquePointer[MutUntrackedOrigin]]
    var hrecs: Optional[UnsafePointer[sam_hrecs_t, MutUntrackedOrigin]]
    var ref_count: uint32_t

